{
  "data_path": "../ecg_afib_data",
  "train_ratio": 0.7,
  "val_ratio": 0.15,
  "test_ratio": 0.15,
  "base_channels": 64,
  "channel_mults": [
    1,
    2,
    4,
    8
  ],
  "time_embed_dim": 256,
  "class_embed_dim": 256,
  "dropout": 0.1,
  "use_content_conditioning": true,
  "content_dim": 512,
  "num_train_timesteps": 1000,
  "beta_start": 0.0001,
  "beta_end": 0.02,
  "beta_schedule": "linear",
  "noise_strength_min": 0.3,
  "noise_strength_max": 0.8,
  "epochs": 100,
  "batch_size": 32,
  "lr": 0.0001,
  "weight_decay": 0.0001,
  "grad_clip": 1.0,
  "lambda_noise": 1.0,
  "lambda_content": 0.5,
  "lambda_classification": 0.1,
  "lambda_reconstruction": 0.5,
  "patience": 15,
  "min_delta": 0.001,
  "save_every": 5,
  "output_dir": "./checkpoints",
  "log_dir": "./outputs/training_logs",
  "classifier_path": "../best_model/best_model.pth"
}